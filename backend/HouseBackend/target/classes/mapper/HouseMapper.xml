<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.housebackend.mapper.HouseMapper">
    <select id="getAll" resultType="org.example.housebackend.entity.House">
        SELECT * FROM house
    </select>

    <update id="updateHouse">
        UPDATE house
        SET status = #{status}
        WHERE id = #{id}
    </update>
</mapper>