<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.housebackend.mapper.StatsMapper">

    <!-- 空房数量 -->
    <select id="countEmptyHouses" resultType="int">
        SELECT COUNT(*)
        FROM house
        WHERE status = '空房'
    </select>

    <!-- 已分配数量 -->
    <select id="countAllocatedHouses" resultType="int">
        SELECT COUNT(*)
        FROM house
        WHERE status = '已分配'
    </select>

    <!-- 申请总数 -->
    <select id="countApplications" resultType="int">
        SELECT COUNT(*)
        FROM application
    </select>

    <!-- 阈值分数（最小标准） -->
    <select id="getMinThresholdScore" resultType="int">
        SELECT MIN(min_score)
        FROM housing_standard
    </select>

</mapper>